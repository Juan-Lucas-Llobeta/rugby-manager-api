                    "type": "string",
                    "description": "Team name"
                  },
                  "club": {
                    "type": "string",
                    "description": "Club name (optional)"
                  },
                  "temporada_id": {
                    "type": "integer",
                    "description": "Season ID (optional)"
                  }
