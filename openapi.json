{
  "openapi": "3.0.0",
  "info": {
    "title": "Rugby Manager API",
    "version": "1.0.0",
    "description": "API para gestión de equipos de rugby - Jugadores, Partidos, Entrenamientos y más"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Servidor de desarrollo"
    }
