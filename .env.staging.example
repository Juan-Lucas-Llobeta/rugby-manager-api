# Staging environment template — copy to your host's secret manager or .env on staging server

DB_HOST=your-staging-db-host
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=rugby_manager_staging

PORT=3001
NODE_ENV=production

# Add every browser client origin (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://your-web-staging.example.com

JWT_SECRET=replace_with_random_64_char_string_for_staging
JWT_EXPIRES_IN=24h
