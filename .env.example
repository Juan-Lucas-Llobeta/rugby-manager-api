# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=rugby_manager
# DB_SSL=true  # Uncomment for cloud databases (e.g. Aiven)

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Comma-separated list of allowed origins (add staging/prod web URLs when deployed)
# Local web: http://localhost:5173
# Web staging: https://your-web-staging.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration - CHANGE THIS IN PRODUCTION (min 32 chars)
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_EXPIRES_IN=24h
